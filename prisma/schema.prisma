generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum SubStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum XpReasonType {
  CODE_SUBMISSION_PASS
  CODE_SUBMISSION_FAIL
  CODE_FIRST_SOLVE_BONUS
  SD_SUBMISSION
  DAILY_STREAK_BONUS
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  xp           Int           @default(0)
  createdAt    DateTime      @default(now())
  submissions  Submission[]
  subscription Subscription?
  dailyUsage   DailyUsage[]

  systemDesignSubmissions SystemDesignSubmission[]
  xpTransactions          XpTransaction[]
  sdComments              SdComment[]
  sdCommentLikes          SdCommentLike[]
  sdCanvasStates          SdCanvasState[]

  // Engineering Fundamentals
  topicProgress       UserTopicProgress[]
  scenarioAttempts    UserScenarioAttempt[]
  projectPrepSessions ProjectPrepSession[]
  templateViews       UserTemplateView[]
}

model Problem {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  difficulty  Difficulty
  companies   String[]
  tags        String[]
  createdAt   DateTime     @default(now())
  testCases   TestCase[]
  submissions Submission[]
}

model TestCase {
  id             String             @id @default(cuid())
  problemId      String
  problem        Problem            @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input          String
  expectedOutput String
  isHidden       Boolean            @default(false)
  results        SubmissionResult[]
}

model Submission {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  problemId     String
  problem       Problem            @relation(fields: [problemId], references: [id])
  code          String             @db.Text
  language      String
  languageId    Int
  status        SubmissionStatus   @default(PENDING)
  executionTime Float?
  createdAt     DateTime           @default(now())
  results       SubmissionResult[]
  feedback      Feedback?
}

model SubmissionResult {
  id             String     @id @default(cuid())
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCaseId     String
  testCase       TestCase   @relation(fields: [testCaseId], references: [id])
  stdout         String?
  expectedOutput String
  passed         Boolean
  executionTime  Float?
}

model Feedback {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  message      String     @db.Text
  createdAt    DateTime   @default(now())
}

model Subscription {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id])
  plan              SubscriptionPlan @default(FREE)
  status            SubStatus        @default(ACTIVE)
  startsAt          DateTime         @default(now())
  expiresAt         DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model DailyUsage {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  date     String // "YYYY-MM-DD" UTC
  runCount Int    @default(0)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// System Design Module
// ─────────────────────────────────────────────

model SystemDesignQuestion {
  id          String   @id @default(cuid())
  title       String
  difficulty  Difficulty
  description String   @db.Text

  // Functional & non-functional requirements
  requirements String[]
  // Scale, latency, storage constraints etc.
  constraints  String[]
  // Progressive hints without giving the full answer away
  hints        String[]

  // Stored as flexible JSON to support future diagram builder & AI feedback
  // Shape: { overview, steps[], tradeoffs[], diagram }
  solution Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions  SystemDesignSubmission[]
  sdComments   SdComment[]
  sdCanvasStates SdCanvasState[]
}

model SystemDesignSubmission {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id])
  answerText String               @db.Text
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

// ─────────────────────────────────────────────
// XP System
// ─────────────────────────────────────────────

model XpTransaction {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Int
  reason      XpReasonType
  referenceId String?
  createdAt   DateTime      @default(now())
}

// ─────────────────────────────────────────────
// System Design — Discussion
// ─────────────────────────────────────────────

model SdComment {
  id         String               @id @default(cuid())
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  text       String               @db.Text
  likesCount Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  likes      SdCommentLike[]
}

model SdCommentLike {
  id        String    @id @default(cuid())
  commentId String
  comment   SdComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([commentId, userId])
}

// ─────────────────────────────────────────────
// System Design — Canvas State
// ─────────────────────────────────────────────

model SdCanvasState {
  id         String               @id @default(cuid())
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  nodesJson  String               @db.Text
  edgesJson  String               @db.Text
  updatedAt  DateTime             @updatedAt

  @@unique([questionId, userId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Fundamentals
// ─────────────────────────────────────────────

model FundamentalTopic {
  id          String   @id @default(cuid())
  title       String   @unique
  description String
  icon        String
  accentColor String
  borderColor String
  glowColor   String
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  concepts    TopicConcept[]
  qna         TopicQnA[]
  quiz        TopicQuiz[]
  progress    UserTopicProgress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TopicConcept {
  id      String           @id @default(cuid())
  topicId String
  topic   FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title   String
  body    String           @db.Text
  order   Int              @default(0)
}

model TopicQnA {
  id       String           @id @default(cuid())
  topicId  String
  topic    FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  question String           @db.Text
  answer   String           @db.Text
  order    Int              @default(0)
}

model TopicQuiz {
  id           String           @id @default(cuid())
  topicId      String
  topic        FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  question     String           @db.Text
  options      Json
  correctIndex Int
  explanation  String           @db.Text
  order        Int              @default(0)
}

model UserTopicProgress {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId     String
  topic       FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  completedAt DateTime         @default(now())

  @@unique([userId, topicId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Debugging Lab
// ─────────────────────────────────────────────

model DebugScenario {
  id           String   @id @default(cuid())
  title        String   @unique
  description  String   @db.Text
  difficulty   Difficulty
  hypotheses   Json
  correctIndex Int
  explanation  String   @db.Text
  isPublished  Boolean  @default(true)
  order        Int      @default(0)
  attempts     UserScenarioAttempt[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserScenarioAttempt {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId String
  scenario   DebugScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  picked     Int
  correct    Boolean
  createdAt  DateTime      @default(now())

  @@unique([userId, scenarioId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Project Prep
// ─────────────────────────────────────────────

model ProjectPrepSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String   @db.Text
  questions   Json
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Communication
// ─────────────────────────────────────────────

model CommTemplate {
  id          String   @id @default(cuid())
  title       String   @unique
  description String
  icon        String
  steps       Json
  example     String   @db.Text
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  views       UserTemplateView[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserTemplateView {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   CommTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  viewedAt   DateTime     @default(now())

  @@unique([userId, templateId])
}
