generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum SubStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum XpReasonType {
  CODE_SUBMISSION_PASS
  CODE_SUBMISSION_FAIL
  CODE_FIRST_SOLVE_BONUS
  SD_SUBMISSION
  DAILY_STREAK_BONUS
  ASSESSMENT_COMPLETION
}

enum AssessmentQuestionType {
  MCQ
  MULTI_SELECT
  TRUE_FALSE
  CODE_OUTPUT
  SCENARIO_BASED
}

enum AssessmentDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AssessmentReviewStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  xp           Int           @default(0)
  createdAt    DateTime      @default(now())
  submissions  Submission[]
  subscription Subscription?
  dailyUsage   DailyUsage[]

  systemDesignSubmissions SystemDesignSubmission[]
  xpTransactions          XpTransaction[]
  sdComments              SdComment[]
  sdCommentLikes          SdCommentLike[]
  sdCanvasStates          SdCanvasState[]

  // Engineering Fundamentals
  topicProgress       UserTopicProgress[]
  scenarioAttempts    UserScenarioAttempt[]
  projectPrepSessions ProjectPrepSession[]
  templateViews       UserTemplateView[]
  refreshTokens       RefreshToken[]
  assessmentQuestionsCreated AssessmentQuestion[]      @relation("AssessmentQuestionCreatedBy")
  assessmentAttempts         AssessmentAttempt[]
  assessmentAnswerEvents     AssessmentAnswerEvent[]
  bookmarkedQuestions        AssessmentQuestionBookmark[]
  generatedAssessments       GeneratedAssessment[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, revoked])
  @@index([expiresAt])
}

model Problem {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  difficulty  Difficulty
  companies   String[]
  tags        String[]
  createdAt   DateTime     @default(now())
  testCases   TestCase[]
  submissions Submission[]
}

model TestCase {
  id             String             @id @default(cuid())
  problemId      String
  problem        Problem            @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input          String
  expectedOutput String
  isHidden       Boolean            @default(false)
  results        SubmissionResult[]
}

model Submission {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  problemId     String
  problem       Problem            @relation(fields: [problemId], references: [id])
  code          String             @db.Text
  language      String
  languageId    Int
  status        SubmissionStatus   @default(PENDING)
  executionTime Float?
  createdAt     DateTime           @default(now())
  results       SubmissionResult[]
  feedback      Feedback?
}

model SubmissionResult {
  id             String     @id @default(cuid())
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCaseId     String
  testCase       TestCase   @relation(fields: [testCaseId], references: [id])
  stdout         String?
  expectedOutput String
  passed         Boolean
  executionTime  Float?
}

model Feedback {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  message      String     @db.Text
  createdAt    DateTime   @default(now())
}

model Subscription {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id])
  plan              SubscriptionPlan @default(FREE)
  status            SubStatus        @default(ACTIVE)
  startsAt          DateTime         @default(now())
  expiresAt         DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model DailyUsage {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  date     String // "YYYY-MM-DD" UTC
  runCount Int    @default(0)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// System Design Module
// ─────────────────────────────────────────────

model SystemDesignQuestion {
  id          String   @id @default(cuid())
  title       String
  difficulty  Difficulty
  description String   @db.Text

  // Functional & non-functional requirements
  requirements String[]
  // Scale, latency, storage constraints etc.
  constraints  String[]
  // Progressive hints without giving the full answer away
  hints        String[]

  // Stored as flexible JSON to support future diagram builder & AI feedback
  // Shape: { overview, steps[], tradeoffs[], diagram }
  solution Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions  SystemDesignSubmission[]
  sdComments   SdComment[]
  sdCanvasStates SdCanvasState[]
}

model SystemDesignSubmission {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id])
  answerText String               @db.Text
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

// ─────────────────────────────────────────────
// XP System
// ─────────────────────────────────────────────

model XpTransaction {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Int
  reason      XpReasonType
  referenceId String?
  createdAt   DateTime      @default(now())
}

// ─────────────────────────────────────────────
// System Design — Discussion
// ─────────────────────────────────────────────

model SdComment {
  id         String               @id @default(cuid())
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  text       String               @db.Text
  likesCount Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  likes      SdCommentLike[]
}

model SdCommentLike {
  id        String    @id @default(cuid())
  commentId String
  comment   SdComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([commentId, userId])
}

// ─────────────────────────────────────────────
// System Design — Canvas State
// ─────────────────────────────────────────────

model SdCanvasState {
  id         String               @id @default(cuid())
  questionId String
  question   SystemDesignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id])
  nodesJson  String               @db.Text
  edgesJson  String               @db.Text
  updatedAt  DateTime             @updatedAt

  @@unique([questionId, userId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Fundamentals
// ─────────────────────────────────────────────

model FundamentalTopic {
  id          String   @id @default(cuid())
  title       String   @unique
  description String
  icon        String
  accentColor String
  borderColor String
  glowColor   String
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  concepts    TopicConcept[]
  qna         TopicQnA[]
  quiz        TopicQuiz[]
  progress    UserTopicProgress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TopicConcept {
  id      String           @id @default(cuid())
  topicId String
  topic   FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title   String
  body    String           @db.Text
  order   Int              @default(0)
}

model TopicQnA {
  id       String           @id @default(cuid())
  topicId  String
  topic    FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  question String           @db.Text
  answer   String           @db.Text
  order    Int              @default(0)
}

model TopicQuiz {
  id           String           @id @default(cuid())
  topicId      String
  topic        FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  question     String           @db.Text
  options      Json
  correctIndex Int
  explanation  String           @db.Text
  order        Int              @default(0)
}

model UserTopicProgress {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId     String
  topic       FundamentalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  completedAt DateTime         @default(now())

  @@unique([userId, topicId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Debugging Lab
// ─────────────────────────────────────────────

model DebugScenario {
  id           String   @id @default(cuid())
  title        String   @unique
  description  String   @db.Text
  difficulty   Difficulty
  hypotheses   Json
  correctIndex Int
  explanation  String   @db.Text
  isPublished  Boolean  @default(true)
  order        Int      @default(0)
  attempts     UserScenarioAttempt[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserScenarioAttempt {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId String
  scenario   DebugScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  picked     Int
  correct    Boolean
  createdAt  DateTime      @default(now())

  @@unique([userId, scenarioId])
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Project Prep
// ─────────────────────────────────────────────

model ProjectPrepSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String   @db.Text
  questions   Json
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// Engineering Fundamentals — Communication
// ─────────────────────────────────────────────

model CommTemplate {
  id          String   @id @default(cuid())
  title       String   @unique
  description String
  icon        String
  steps       Json
  example     String   @db.Text
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  views       UserTemplateView[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserTemplateView {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   CommTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  viewedAt   DateTime     @default(now())

  @@unique([userId, templateId])
}

model AssessmentCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  icon        String?
  isActive    Boolean           @default(true)
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  topics      AssessmentTopic[]
  questions   AssessmentQuestion[]
  generatedAssessments GeneratedAssessment[]

  @@index([isActive, createdAt])
}

model AssessmentTopic {
  id          String               @id @default(cuid())
  categoryId  String
  category    AssessmentCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  isActive    Boolean              @default(true)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  questions   AssessmentQuestion[]

  @@unique([categoryId, slug])
  @@index([categoryId, isActive, createdAt])
}

model AssessmentQuestion {
  id                    String                       @id @default(cuid())
  categoryId            String
  category              AssessmentCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  topicId               String?
  topic                 AssessmentTopic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  questionType          AssessmentQuestionType
  difficulty            AssessmentDifficulty
  question              String                       @db.Text
  options               Json?
  correctAnswer         Json
  explanation           String?                      @db.Text
  tags                  String[]
  isActive              Boolean                      @default(true)
  estimatedTimeSeconds  Int                          @default(60)
  metadata              Json?
  reviewStatus          AssessmentReviewStatus       @default(DRAFT)
  createdBy             String
  creator               User                         @relation("AssessmentQuestionCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  deletedAt             DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  generatedItems        GeneratedAssessmentQuestion[]
  answerEvents          AssessmentAnswerEvent[]
  bookmarks             AssessmentQuestionBookmark[]

  @@index([categoryId, topicId, difficulty, questionType])
  @@index([isActive, reviewStatus, createdAt])
  @@index([createdBy, createdAt])
}

model GeneratedAssessment {
  id                    String                        @id @default(cuid())
  generatedBy           String
  generator             User                          @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
  title                 String?
  categoryId            String?
  category              AssessmentCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  config                Json
  estimatedDurationSecs Int
  questionCount         Int
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  questions             GeneratedAssessmentQuestion[]
  attempts              AssessmentAttempt[]

  @@index([generatedBy, createdAt])
}

model GeneratedAssessmentQuestion {
  id             String               @id @default(cuid())
  assessmentId   String
  assessment     GeneratedAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId     String
  question       AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Restrict)
  sequence       Int
  createdAt      DateTime             @default(now())

  @@unique([assessmentId, questionId])
  @@unique([assessmentId, sequence])
  @@index([questionId])
}

model AssessmentAttempt {
  id                    String                  @id @default(cuid())
  userId                String
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId          String
  assessment            GeneratedAssessment     @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  status                AssessmentAttemptStatus @default(IN_PROGRESS)
  startedAt             DateTime                @default(now())
  endedAt               DateTime?
  totalQuestions        Int                     @default(0)
  answeredQuestions     Int                     @default(0)
  score                 Float                   @default(0)
  accuracy              Float                   @default(0)
  totalTimeSpentSeconds Int                     @default(0)
  metadata              Json?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  answerEvents          AssessmentAnswerEvent[]

  @@index([userId, createdAt])
  @@index([assessmentId, createdAt])
}

model AssessmentAnswerEvent {
  id                  String              @id @default(cuid())
  attemptId           String
  attempt             AssessmentAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId          String
  question            AssessmentQuestion  @relation(fields: [questionId], references: [id], onDelete: Restrict)
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedAnswer      Json?
  isCorrect           Boolean?
  markedForReview     Boolean             @default(false)
  confidenceLevel     Int?
  timeSpentSeconds    Int                 @default(0)
  isFinal             Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([attemptId, questionId])
  @@index([userId, createdAt])
}

model AssessmentQuestionBookmark {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   AssessmentQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())

  @@unique([userId, questionId])
  @@index([questionId])
}
